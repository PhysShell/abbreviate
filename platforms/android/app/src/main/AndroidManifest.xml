<?xml version="1.0" encoding="utf-8"?>
<!-- No INTERNET permission: the engine is fully offline, and that guarantee is
     verifiable by reading this manifest. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:label="Abbrev Scratchpad"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.DarkActionBar">

        <activity
            android:name=".ScratchpadActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Abbreviation IME. The same SuggestionController/engine as the
             scratchpad; only the TextHost differs (InputConnection). -->
        <service
            android:name=".ime.AbbrevImeService"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
        <activity
            android:name=".TestActivity"
            android:exported="false"
            android:label="Тест набора"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>
